 // Единый обработчик для всех цифровых кнопок
 private: System::Void Digit_Click(System::Object^ sender, System::EventArgs^ e) {
  Button^ btn = safe_cast<Button^>(sender);

  if (txtDisplay->Text == "0" || isOpPressed) {
   txtDisplay->Text = btn->Text;
   isOpPressed = false;
  } else {
   txtDisplay->Text += btn->Text;
  }
 }

 // Кнопка Сложение (+)
 private: System::Void btnAdd_Click(System::Object^ sender, System::EventArgs^ e) {
  firstNum = System::Convert::ToDouble(txtDisplay->Text);
  operation = '+';
  isOpPressed = true;
 }

 // Кнопка Вычитание (-)
 private: System::Void btnSub_Click(System::Object^ sender, System::EventArgs^ e) {
  firstNum = System::Convert::ToDouble(txtDisplay->Text);
  operation = '-';
  isOpPressed = true;
 }

 // Кнопка Равно (=)
 private: System::Void btnEqual_Click(System::Object^ sender, System::EventArgs^ e) {
  secondNum = System::Convert::ToDouble(txtDisplay->Text);

switch (operation) {
   case '+':
    result = firstNum + secondNum;
    break;
   case '-':
    result = firstNum - secondNum;
    break;
   default:
    return;
  }

  txtDisplay->Text = System::Convert::ToString(result);
  isOpPressed = true; 
 }

 // Кнопка Очистить (C)
 private: System::Void btnClear_Click(System::Object^ sender, System::EventArgs^ e) {
  txtDisplay->Text = "0";
  firstNum = 0;
  secondNum = 0;
  result = 0;
  operation = ' ';
  isOpPressed = false;
 }
