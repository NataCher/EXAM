        // Функция обновления ListBox на основе текущего состояния списка
        void UpdateListBox()
        {
            listBoxElements->Items->Clear();
            Node* current = head;
            while (current != nullptr)
            {
                listBoxElements->Items->Add(current->data);
                current = current->next;
            }
        }

        // Вспомогательная функция полной очистки списка (без return)
        void ClearList()
        {
            while (head != nullptr)
            {
                Node* temp = head;
                head = head->next;
                delete temp;
            }
        }

        // 1. Создание списка
        System::Void создатьСписокToolStripMenuItem_Click(System::Object^ sender, System::EventArgs^ e)
        {
            ClearList();
            head = nullptr;
            
            // Создаем начальный элемент со значением 0 (или из текстового поля, если введено)
            int value = 0;
            Int32::TryParse(textBoxInput->Text, value);

            head = new Node();
            head->data = value;
            head->next = nullptr;

            UpdateListBox();
        }

        // 2. Добавление элемента в конец списка
        System::Void добавитьЭлементToolStripMenuItem_Click(System::Object^ sender, System::EventArgs^ e)
        {
            int value = 0;
            if (Int32::TryParse(textBoxInput->Text, value))
            {
                Node* newNode = new Node();
                newNode->data = value;
                newNode->next = nullptr;

                if (head == nullptr)
                {
                    head = newNode;
                }
                else
                {
                    Node* current = head;
                    while (current->next != nullptr)
                    {
                        current = current->next;
                    }
                    current->next = newNode;
                }
                UpdateListBox();
            }
            else
            {
                MessageBox::Show("Пожалуйста, введите корректное целое число.", "Ошибка ввода");
            }
        }

        // 3. Удаление элемента по значению (первого найденного)
        System::Void удалитьЭлементToolStripMenuItem_Click(System::Object^ sender, System::EventArgs^ e)
        {
            int value = 0;
            if (Int32::TryParse(textBoxInput->Text, value) && head != nullptr)
            {
                // Случай 1: Удаляемый элемент — это голова списка
                if (head->data == value)
                {
                    Node* temp = head;
                    head = head->next;
                    delete temp;
                }
                else
                {
                    // Случай 2: Элемент находится дальше в списке
                    Node* current = head;
                    bool found = false;

                    // Идем по списку, пока не дойдем до конца или пока не найдем элемент
                    while (current->next != nullptr && !found)
                    {
                        if (current->next->data == value)
                        {
                            Node* temp = current->next;
                            current->next = current->next->next;
                            delete temp;
                            found = true; // Выставляем флаг, чтобы завершить цикл без break
                        }
                        else
                        {
                            current = current->next;
                        }
                    }
                }
                UpdateListBox();
            }
        }

        // 4. Очистка списка
        System::Void очиститьСписокToolStripMenuItem_Click(System::Object^ sender, System::EventArgs^ e)
